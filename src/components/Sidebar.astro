---
import DefaultPageSidebar from "@astrojs/starlight/components/Sidebar.astro";

if (Array.isArray(Astro.locals.starlightRoute.sidebar)) {
	Astro.locals.starlightRoute.sidebar.unshift(
		{
			label: "E-book",
			badge: undefined,
			type: "link",
			isCurrent: false,
			attrs: {},
			href: "/#support-me",
		},
		{
			label: "Feedback",
			badge: {
				text: "New",
				variant: "success",
			},
			type: "link",
			isCurrent: false,
			attrs: {},
			href: "/feedback",
		},
	);
}
---

{
	(
		// @ts-ignore
		<DefaultPageSidebar {...Astro.props}>
			{" "}
			<slot />{" "}
		</DefaultPageSidebar>
	)
}

<script>
	const activeEl = document.querySelector(
		"#starlight__sidebar a[aria-current]",
	);
	if (activeEl instanceof HTMLElement) {
		activeEl.scrollIntoView({
			behavior: "instant",
			block: "center",
		});
	}
</script>
