---
import Default from "@astrojs/starlight/components/MarkdownContent.astro";
import type { Props } from "@astrojs/starlight/props";
import ContentEntries from "./ContentEntries.astro";

const isHomepage = Astro.props.slug === "";
---

{
	isHomepage ? (
		<div class="sl-markdown-content">
			<p>
				It's a website of{" "}
				<a href="https://sahithyan.dev" class="text-[var(--sl-color-accent)]">
					my
				</a>{" "}
				short notes of my 1st semester of Engineering at University of Moratuwa.
			</p>
			<p>
				You can contact <a href="https://sahithyan.dev">me</a>, if something is
				missing or you find anything wrong. This wouldn't be possible without
				the help of my friends. Huge thanks for everyone involved.
			</p>
			<h2 id="why">Why?</h2>{" "}
			<ul>
				<li>Indexable. Exercise books are not.</li>{" "}
				<li>Accessible from everywhere.</li> <li>Helpful to everyone.</li>{" "}
			</ul>{" "}
			<h2 id="support-me">Want to support?</h2>
			<p>
				You can download the notes as a PDF file from{" "}
				<a href="https://buymeacoffee.com/rrziwfs" target="_blank">
					Buy Me a Coffee
				</a>{" "}
				for $5.
			</p>
			<h2 class="mb-1">Content Included</h2>
			<div id="content-included">
				<p>
					<Fragment>
						<strong class="text-inherit underline underline-offset-4">
							All the content except the images in this website is shared under
							<a
								href="/license"
								id="license"
								class="text-[var(--sl-color-accent)]"
							>
								CC BY-NC-ND 4.0
							</a>
							.
						</strong>
						<br />
					</Fragment>
					Images are either mine, or one of my friend's or from the internet or
					from the lecture notes.
				</p>
				<ContentEntries entries={Astro.props.sidebar} />
			</div>{" "}
		</div>
	) : (
		<div>
			{/* @ts-ignore */}
			<Default {...Astro.props} data-pagefind-body>
				<slot />
			</Default>
		</div>
	)
}
